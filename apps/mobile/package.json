{
  "name": "@grove/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "build": "pnpm run build:android && pnpm run build:ios",
    "build:android": "expo export --platform android",
    "build:ios": "expo export --platform ios",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@grove/core": "workspace:*",
    "expo": "^53.0.0",
    "expo-router": "^4.0.0",
    "nativewind": "^4.0.0",
    "react": "^19.0.0",
    "react-native": "^0.76.0",
    "react-native-css-interop": "^0.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  }
}
