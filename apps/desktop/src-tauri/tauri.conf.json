{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grove",
  "version": "0.1.0",
  "identifier": "app.grove.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. --filter @grove/desktop dev",
    "beforeBuildCommand": "pnpm --dir ../.. --filter @grove/desktop build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"]
  },
  "app": {
    "windows": [
      {
        "title": "Grove",
        "width": 1280,
        "height": 820
      }
    ]
  }
}
